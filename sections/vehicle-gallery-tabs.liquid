{%- comment -%}theme-check-disable SchemaJsonFormat{%- endcomment -%}

{%- if section.index < 3 or request.design_mode -%}
    {{ 'component-section-tabs.css' | asset_url | stylesheet_tag }}
  {%- else -%}
    <link rel="stylesheet" href="{{ 'component-section-tabs.css' | asset_url }}" media="print" onload="this.media='all'">
  {%- endif -%}
  
  {%- assign variants = collection.metafields.vehicle_config.variants.value -%}
  
  {% if variants and variants.size > 0 %}
  
    <div class="color-{{ section.settings.color_scheme }} isolate gradient">
      <div class="section__inner {{ section.settings.top_padding }} {{ section.settings.bottom_padding }}">
  
        {% render 'standard-section-heading',
            section_name: 'vehicle-gallery-tabs',
            section: section
        %}
  
        {% comment %} Tab navigation {% endcomment %}
        <div class="page-width flex justify-{{ section.settings.tab_alignment }}">
          <div class="horizontal-scroll">
            <div class="block responsive-margin-bottom custom-tabs custom-tabs--{{ section.settings.tab_style }} {{ section.settings.tab_text_size }}">
              {% for variant in variants %}
                <div class="flex">
                    <button
                        class="custom-tab tap-target--small vgt-tab-btn {% if forloop.first %}custom-tab--active{% endif %}"
                        data-target="vgt-panel-{{ section.id }}-{{ variant.gallery_id }}"
                        aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                        role="tab"
                        type="button">
                        {{ variant.label }}
                    </button>
                </div>
              {% endfor %}
            </div>
          </div>
        </div>
  
        {% comment %} Tab panels {% endcomment %}
        <div class="page-width vgt-panels" id="vgt-{{ section.id }}">
          {% for variant in variants %}
            <div
                id="vgt-panel-{{ section.id }}-{{ variant.gallery_id }}"
                class="vgt-panel {% unless forloop.first %}vgt-panel--hidden{% endunless %}"
                role="tabpanel"
                aria-label="{{ variant.label }}">
            <div
                class="lookfy-gallery"
                data-id="{{ variant.gallery_id }}">
            </div>
            </div>
          {% endfor %}
        </div>
  
      </div>
    </div>
  
    <style>
        .vgt-panel--hidden {
          display: none;
        }
      
        .section-vehicle-gallery-tabs .vgt-tab-btn {
          background: none;
          border: none;
          font: inherit;
          color: inherit;
          cursor: pointer;
          -webkit-appearance: none;
          appearance: none;
          text-align: inherit;
          line-height: inherit;
        }
        .section-vehicle-gallery-tabs .vgt-tab-btn.custom-tab--active {
        background-color: rgba(var(--color-background), 1);
        box-shadow: 0 2px 10px rgba(var(--color-foreground), 0.03);
        }
    </style>
  
  <script>
    (function () {
      var container = document.getElementById('vgt-{{ section.id }}');
      if (!container) return;
  
      var sectionEl = container.closest('.color-{{ section.settings.color_scheme }}');
      if (!sectionEl) return;
  
      var buttons = sectionEl.querySelectorAll('.vgt-tab-btn');
      var panels = container.querySelectorAll('.vgt-panel');
      var storageKey = 'vgt-tab-{{ collection.handle }}';
  
      function activateTab(targetId) {
        buttons.forEach(function (b) {
          b.classList.remove('custom-tab--active');
          b.setAttribute('aria-selected', 'false');
        });
  
        panels.forEach(function (panel) {
          panel.classList.add('vgt-panel--hidden');
        });
  
        var targetPanel = document.getElementById(targetId);
        var targetBtn = sectionEl.querySelector('[data-target="' + targetId + '"]');
  
        if (targetPanel) targetPanel.classList.remove('vgt-panel--hidden');
        if (targetBtn) {
          targetBtn.classList.add('custom-tab--active');
          targetBtn.setAttribute('aria-selected', 'true');
        }
      }
  
      // Restore saved tab on page load
      var savedTab = localStorage.getItem(storageKey);
      if (savedTab && document.getElementById(savedTab)) {
        activateTab(savedTab);
      }
  
      // Save tab selection on click
      buttons.forEach(function (btn) {
        btn.addEventListener('click', function () {
          var targetId = btn.getAttribute('data-target');
          activateTab(targetId);
          localStorage.setItem(storageKey, targetId);
        });
      });
    })();
  </script>
  
  {% endif %}
  
