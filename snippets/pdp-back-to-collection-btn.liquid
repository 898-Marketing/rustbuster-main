{% assign back_collection = nil %}

{% for c in product.collections %}
  {% assign variants = c.metafields.vehicle_config.variants.value %}
  {% if variants and variants.size > 0 %}
    {% assign back_collection = c %}
    {% break %}
  {% endif %}
{% endfor %}

{% if back_collection %}
  <a href="{{ back_collection.url }}" class="pdp-back-btn">
    ← Back to {{ back_collection.title }}
  </a>
{% endif %}

<style>
  .pdp-back-btn {
    display: inline-block;
    margin-bottom: 1rem;
    font-size: 0.9rem;
    color: rgba(var(--color-foreground), 0.7);
    text-decoration: none;
    transition: color 0.2s;
  }
  .pdp-back-btn:hover {
    color: rgba(var(--color-foreground), 1);
  }
</style>